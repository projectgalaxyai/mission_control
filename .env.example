# ===========================================
# Mission Control - Environment variables
# Copy to .env.local for local dev, set in Vercel for production
# ===========================================

# --- Auth0 (required for dashboard auth) ---
# From Auth0 Dashboard: Application → Settings
AUTH0_DOMAIN=your-tenant.us.auth0.com
AUTH0_CLIENT_ID=your_client_id
AUTH0_CLIENT_SECRET=your_client_secret
# Generate: openssl rand -hex 32
AUTH0_SECRET=your_32_byte_hex_secret

# Base URL of this app (optional; SDK infers from request in Vercel)
# Local: leave unset or set to http://localhost:3000
# Production: https://dashboard.projectgalaxyai.com
APP_BASE_URL=https://dashboard.projectgalaxyai.com

# --- Mission Control WebSocket server (optional for UI) ---
# Only needed if the UI connects to a separate MC server
# Local: ws://localhost:3001/ws
# Production: wss://your-mc-server.example.com/ws
NEXT_PUBLIC_WS_URL=ws://localhost:3001/ws
